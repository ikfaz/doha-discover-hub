/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.google-analytics.com https://maps.googleapis.com; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: https://cdn.experiencedoha.com https://*.googleapis.com https://*.gstatic.com https://i.ytimg.com; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://www.googleapis.com; frame-src 'self' https://www.youtube.com https://www.google.com;

/blog/*
  Content-Type: text/html; charset=utf-8

/tour/*
  Content-Type: text/html; charset=utf-8
