# END LEGACY TAG REDIRECTS




# Canonical non-root trailing slash normalization on www
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^(.+)/$ https://experiencedoha.com/$1 [R=301,L]

  # Canonical host redirect (www -> apex)
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^(.*)$ https://experiencedoha.com/$1 [R=301,L]

  # 301 Redirects: Common typos and old paths
  RewriteRule ^blogs/?$ /blog [R=301,L]
  RewriteRule ^blogs/([^/]+)/?$ /blog/$1 [R=301,L]
  RewriteRule ^tours/([^/]+)/?$ /tour/$1 [R=301,L]
  RewriteRule ^listings/([^/]+)/?$ /listing/$1 [R=301,L]
  RewriteRule ^privacy/?$ /privacy-policy [R=301,L]
  RewriteRule ^terms/?$ /terms-of-service [R=301,L]
  RewriteRule ^cookies/?$ /cookie-policy [R=301,L]
  RewriteRule ^budget/?$ /budget-planner [R=301,L]
  RewriteRule ^video/?$ /blog [R=301,L]
  RewriteRule ^videos/?$ /blog [R=301,L]
  RewriteRule ^photos/?$ /gallery [R=301,L]

  # Canonical non-root trailing slash normalization on apex
  # NOTE: Only strip trailing slash from asset/static paths (not prerendered routes)
  # %{REQUEST_FILENAME} -d is unreliable on this host; we use URI patterns instead.
  # All app routes are prerendered, so trailing-slash URLs are served by mod_dir below.

  # SSG: serve prerendered index.html for clean URL routes
  # Handles both /path/ and /path (with or without trailing slash)
  # Uses REQUEST_FILENAME which is always the real filesystem path
  RewriteCond %{REQUEST_FILENAME}index.html -f [OR]
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+?)/?$ /$1/index.html [L]

  # React Router: serve index.html for all other routes (SPA fallback)
  # IMPORTANT: Exclude trailing-slash URLs (%{REQUEST_URI} !/$)
  # Trailing-slash requests go to Apache mod_dir, which serves the prerendered
  # DirectoryIndex (index.html) for every SSG route automatically.
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule . /index.html [L]
</IfModule>
