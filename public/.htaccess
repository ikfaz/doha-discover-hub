Options -MultiViews
RewriteEngine On

# SSG + SPA Routing — cPanel/Namecheap-compatible
# Uses [END] instead of [L] to prevent second-pass rewrite loops

# Topic hub pages: /blog/topic/{slug}[/]
RewriteRule ^blog/topic/([^/]+)/?$ /blog/topic/$1/index.html [END]

# Blog article pages: /blog/{slug}[/]
RewriteRule ^blog/([^/]+)/?$ /blog/$1/index.html [END]

# Blog listing: /blog[/]
RewriteRule ^blog/?$ /blog/index.html [END]

# Static app pages
RewriteRule ^about/?$ /about/index.html [END]
RewriteRule ^gallery/?$ /gallery/index.html [END]
RewriteRule ^contact/?$ /contact/index.html [END]
RewriteRule ^budget-planner/?$ /budget-planner/index.html [END]

# Don't rewrite actual files (assets, images, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
# React Router SPA fallback for anything else
RewriteRule . /index.html [L]
