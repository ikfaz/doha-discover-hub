<IfModule mod_headers.c>
  # Security Headers
  Header set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # Content Security Policy (Adjusted for Google Maps, Analytics, YouTube)
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.google-analytics.com https://maps.googleapis.com; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: https://cdn.experiencedoha.com https://*.googleapis.com https://*.gstatic.com https://i.ytimg.com; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://www.googleapis.com; frame-src 'self' https://www.youtube.com https://www.google.com;"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # One-hop canonical redirects for legacy aliases on www host
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^blogs/?$ https://experiencedoha.com/blog [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^blogs/([^/]+)/?$ https://experiencedoha.com/blog/$1 [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^tours/([^/]+)/?$ https://experiencedoha.com/tour/$1 [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^listings/([^/]+)/?$ https://experiencedoha.com/listing/$1 [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^privacy/?$ https://experiencedoha.com/privacy-policy [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^terms/?$ https://experiencedoha.com/terms-of-service [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^cookies/?$ https://experiencedoha.com/cookie-policy [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^budget/?$ https://experiencedoha.com/budget-planner [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^video/?$ https://experiencedoha.com/blog [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^videos/?$ https://experiencedoha.com/blog [R=301,L]
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^photos/?$ https://experiencedoha.com/gallery [R=301,L]

  # Canonical non-root trailing slash normalization on www
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^(.+)/$ https://experiencedoha.com/$1 [R=301,L]

  # Canonical host redirect (www -> apex)
  RewriteCond %{HTTP_HOST} ^www\.experiencedoha\.com$ [NC]
  RewriteRule ^(.*)$ https://experiencedoha.com/$1 [R=301,L]

  # 301 Redirects: Common typos and old paths
  RewriteRule ^blogs/?$ /blog [R=301,L]
  RewriteRule ^blogs/([^/]+)/?$ /blog/$1 [R=301,L]
  RewriteRule ^tours/([^/]+)/?$ /tour/$1 [R=301,L]
  RewriteRule ^listings/([^/]+)/?$ /listing/$1 [R=301,L]
  RewriteRule ^privacy/?$ /privacy-policy [R=301,L]
  RewriteRule ^terms/?$ /terms-of-service [R=301,L]
  RewriteRule ^cookies/?$ /cookie-policy [R=301,L]
  RewriteRule ^budget/?$ /budget-planner [R=301,L]
  RewriteRule ^video/?$ /blog [R=301,L]
  RewriteRule ^videos/?$ /blog [R=301,L]
  RewriteRule ^photos/?$ /gallery [R=301,L]

  # Canonical non-root trailing slash normalization on apex
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # React Router: Redirect all requests to index.html so the app handles routing
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
